<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Box – {{ box.libelle }}</title>
</head>
<body>
<h1>{{ box.libelle }}</h1>

{% if box.kdo and box.message_kdo %}
    <blockquote>{{ box.message_kdo }}</blockquote>
{% endif %}

<p>{{ box.description }}</p>
<p><strong>Montant total :</strong> {{ box.montant | number_format(2, ',', ' ') }} €</p>

<h2>Prestations incluses</h2>
{% if box.prestations is not empty %}
    <table border="1" cellpadding="6">
        <thead>
            <tr>
                <th>Prestation</th>
                <th>Quantité</th>
                <th>Tarif unitaire</th>
            </tr>
        </thead>
        <tbody>
        {% for item in box.prestations %}
            <tr>
                <td>{{ item.presta.libelle }}</td>
                <td>{{ item.quantite }}</td>
                <td>{{ item.presta.tarif | number_format(2, ',', ' ') }} €</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% else %}
    <p>Aucune prestation associée à cette box.</p>
{% endif %}
</body>
</html>
